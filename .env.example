# Supabase Configuration
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Configuration (for AI知书 feature)
# Supported providers: SiliconFlow (recommended), Deepseek, OpenAI, Groq, etc.
# Get your API key from: https://cloud.siliconflow.cn (free tier available)
VITE_AI_API_KEY=your-api-key
VITE_AI_API_URL=https://api.siliconflow.cn/v1
VITE_AI_MODEL=deepseek-ai/DeepSeek-V3
